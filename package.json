{
  "name": "protein-ligand-fe-platform",
  "private": true,
  "version": "1.0.0",
  "description": "高精度蛋白质-配体结合自由能预测与先导化合物优化平台",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "worker:dev": "tsx watch api/worker/index.ts",
    "init:db": "tsx api/scripts/init-db.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.12.12",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "echarts": "^5.5.1",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "lucide-vue-next": "^0.511.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "pinia": "^2.2.4",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.2.5",
    "xstate": "^5.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.3",
    "typescript": "~5.3.3",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.0.12",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vue-tsc": "^1.8.27"
  }
